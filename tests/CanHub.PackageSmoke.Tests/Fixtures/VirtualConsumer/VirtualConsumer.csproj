<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <LangVersion>latest</LangVersion>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <CanHubAdapterVirtualPackageVersion Condition="'$(CanHubAdapterVirtualPackageVersion)' == ''">0.1.0</CanHubAdapterVirtualPackageVersion>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="CanHub.Adapter.Virtual" Version="$(CanHubAdapterVirtualPackageVersion)" />
    <PackageReference Include="Microsoft.Extensions.DependencyInjection" Version="10.0.8" />
  </ItemGroup>
</Project>
