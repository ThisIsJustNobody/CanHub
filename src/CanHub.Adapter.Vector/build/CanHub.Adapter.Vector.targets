<Project>
  <PropertyGroup>
    <_CanHubVectorRuntimeIdentifier>$([System.String]::Copy('$(RuntimeIdentifier)').ToLowerInvariant())</_CanHubVectorRuntimeIdentifier>
    <_CanHubVectorRuntimeIdentifierIsWindows>$([System.String]::Copy('$(RuntimeIdentifier)').ToLowerInvariant().StartsWith('win'))</_CanHubVectorRuntimeIdentifierIsWindows>
    <_CanHubVectorRuntimeIdentifierIsX86>$([System.String]::Copy('$(RuntimeIdentifier)').ToLowerInvariant().EndsWith('-x86'))</_CanHubVectorRuntimeIdentifierIsX86>
    <_CanHubVectorRuntimeIdentifierIsX64>$([System.String]::Copy('$(RuntimeIdentifier)').ToLowerInvariant().EndsWith('-x64'))</_CanHubVectorRuntimeIdentifierIsX64>
    <_CanHubVectorPlatformTarget>$([System.String]::Copy('$(PlatformTarget)').ToLowerInvariant())</_CanHubVectorPlatformTarget>
    <_CanHubVectorHostArchitecture>$([System.Runtime.InteropServices.RuntimeInformation]::ProcessArchitecture)</_CanHubVectorHostArchitecture>
  </PropertyGroup>

  <PropertyGroup>
    <_CanHubVectorHostArchitecture>$([System.String]::Copy('$(_CanHubVectorHostArchitecture)').ToLowerInvariant())</_CanHubVectorHostArchitecture>
  </PropertyGroup>

  <PropertyGroup>
    <_CanHubVectorNativeRid Condition="'$(_CanHubVectorRuntimeIdentifier)' != '' and '$(_CanHubVectorRuntimeIdentifierIsWindows)' == 'True' and '$(_CanHubVectorRuntimeIdentifierIsX86)' == 'True'">win-x86</_CanHubVectorNativeRid>
    <_CanHubVectorNativeRid Condition="'$(_CanHubVectorRuntimeIdentifier)' != '' and '$(_CanHubVectorRuntimeIdentifierIsWindows)' == 'True' and '$(_CanHubVectorRuntimeIdentifierIsX64)' == 'True'">win-x64</_CanHubVectorNativeRid>
    <_CanHubVectorNativeRid Condition="'$(_CanHubVectorNativeRid)' == '' and '$(_CanHubVectorRuntimeIdentifier)' == '' and '$(_CanHubVectorPlatformTarget)' == 'x86'">win-x86</_CanHubVectorNativeRid>
    <_CanHubVectorNativeRid Condition="'$(_CanHubVectorNativeRid)' == '' and '$(_CanHubVectorRuntimeIdentifier)' == '' and '$(_CanHubVectorPlatformTarget)' == 'x64'">win-x64</_CanHubVectorNativeRid>
    <_CanHubVectorNativeRid Condition="'$(_CanHubVectorNativeRid)' == '' and '$(_CanHubVectorRuntimeIdentifier)' == '' and '$(OS)' == 'Windows_NT' and '$(_CanHubVectorHostArchitecture)' == 'x86'">win-x86</_CanHubVectorNativeRid>
    <_CanHubVectorNativeRid Condition="'$(_CanHubVectorNativeRid)' == '' and '$(_CanHubVectorRuntimeIdentifier)' == '' and '$(OS)' == 'Windows_NT' and '$(_CanHubVectorHostArchitecture)' == 'x64'">win-x64</_CanHubVectorNativeRid>
    <_CanHubVectorNativeArch Condition="'$(_CanHubVectorNativeRid)' == 'win-x86'">x86</_CanHubVectorNativeArch>
    <_CanHubVectorNativeArch Condition="'$(_CanHubVectorNativeRid)' == 'win-x64'">x64</_CanHubVectorNativeArch>
  </PropertyGroup>

  <ItemGroup Condition="'$(_CanHubVectorNativeRid)' != ''">
    <CanHubVectorNative Include="$(MSBuildThisFileDirectory)native\$(_CanHubVectorNativeRid)\*" />
  </ItemGroup>

  <Target Name="CopyCanHubVectorNative" AfterTargets="Build" Condition="'@(CanHubVectorNative)' != ''">
    <Copy SourceFiles="@(CanHubVectorNative)"
          DestinationFiles="@(CanHubVectorNative->'$(OutputPath)canhub\vector\$(_CanHubVectorNativeArch)\%(Filename)%(Extension)')"
          SkipUnchangedFiles="true" />
  </Target>

  <Target Name="CopyCanHubVectorNativeToPublish" AfterTargets="Publish" Condition="'@(CanHubVectorNative)' != '' and '$(PublishDir)' != ''">
    <Copy SourceFiles="@(CanHubVectorNative)"
          DestinationFiles="@(CanHubVectorNative->'$(PublishDir)canhub\vector\$(_CanHubVectorNativeArch)\%(Filename)%(Extension)')"
          SkipUnchangedFiles="true" />
  </Target>
</Project>
