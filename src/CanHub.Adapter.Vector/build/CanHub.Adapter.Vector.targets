<Project>
  <PropertyGroup>
    <_CanHubVectorRuntimeIdentifier>$([System.String]::Copy('$(RuntimeIdentifier)').ToLowerInvariant())</_CanHubVectorRuntimeIdentifier>
    <_CanHubVectorRuntimeIdentifierIsWindows>$([System.String]::Copy('$(RuntimeIdentifier)').ToLowerInvariant().StartsWith('win'))</_CanHubVectorRuntimeIdentifierIsWindows>
    <_CanHubVectorRuntimeIdentifierIsX86>$([System.String]::Copy('$(RuntimeIdentifier)').ToLowerInvariant().EndsWith('-x86'))</_CanHubVectorRuntimeIdentifierIsX86>
    <_CanHubVectorRuntimeIdentifierIsX64>$([System.String]::Copy('$(RuntimeIdentifier)').ToLowerInvariant().EndsWith('-x64'))</_CanHubVectorRuntimeIdentifierIsX64>
    <_CanHubVectorPlatformTarget>$([System.String]::Copy('$(PlatformTarget)').ToLowerInvariant())</_CanHubVectorPlatformTarget>
    <_CanHubVectorPlatform>$([System.String]::Copy('$(Platform)').ToLowerInvariant())</_CanHubVectorPlatform>
  </PropertyGroup>

  <PropertyGroup Condition="'$(_CanHubVectorRuntimeIdentifier)' != '' and '$(_CanHubVectorRuntimeIdentifierIsWindows)' == 'True'">
    <_CanHubVectorNativeRid Condition="'$(_CanHubVectorRuntimeIdentifierIsX86)' == 'True'">win-x86</_CanHubVectorNativeRid>
    <_CanHubVectorNativeRid Condition="'$(_CanHubVectorRuntimeIdentifierIsX64)' == 'True'">win-x64</_CanHubVectorNativeRid>
  </PropertyGroup>

  <PropertyGroup Condition="'$(_CanHubVectorRuntimeIdentifier)' == '' and '$(OS)' == 'Windows_NT'">
    <_CanHubVectorNativeRid Condition="'$(_CanHubVectorNativeRid)' == '' and ('$(_CanHubVectorPlatformTarget)' == 'x86' or '$(_CanHubVectorPlatform)' == 'x86')">win-x86</_CanHubVectorNativeRid>
    <_CanHubVectorNativeRid Condition="'$(_CanHubVectorNativeRid)' == '' and ('$(_CanHubVectorPlatformTarget)' == 'x64' or '$(_CanHubVectorPlatform)' == 'x64')">win-x64</_CanHubVectorNativeRid>
    <_CanHubVectorNativeRid Condition="'$(_CanHubVectorNativeRid)' == '' and '$(PROCESSOR_ARCHITECTURE)' == 'x86' and '$(PROCESSOR_ARCHITEW6432)' == ''">win-x86</_CanHubVectorNativeRid>
    <_CanHubVectorNativeRid Condition="'$(_CanHubVectorNativeRid)' == ''">win-x64</_CanHubVectorNativeRid>
  </PropertyGroup>

  <ItemGroup Condition="'$(_CanHubVectorNativeRid)' == 'win-x64'">
    <Content Include="$(MSBuildThisFileDirectory)..\runtimes\win-x64\native\vxlapi64.dll"
             CopyToOutputDirectory="PreserveNewest"
             Link="vxlapi64.dll" />
  </ItemGroup>

  <ItemGroup Condition="'$(_CanHubVectorNativeRid)' == 'win-x86'">
    <Content Include="$(MSBuildThisFileDirectory)..\runtimes\win-x86\native\vxlapi.dll"
             CopyToOutputDirectory="PreserveNewest"
             Link="vxlapi.dll" />
  </ItemGroup>
</Project>
